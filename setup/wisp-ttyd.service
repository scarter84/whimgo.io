[Unit]
Description=WISP ttyd -- Web terminal for Whim operator access
After=network.target tailscaled.service
Wants=tailscaled.service

[Service]
Type=simple
ExecStart=/usr/bin/ttyd -p 7681 -i 100.69.17.20 -t fontSize=14 -t fontFamily=JetBrains\ Mono,monospace -t theme={"background":"#0a0a0a","foreground":"#dce4ee","cursor":"#00ff00"} /bin/bash
Restart=on-failure
RestartSec=5
User=tommymunro
Environment=TERM=xterm-256color

[Install]
WantedBy=multi-user.target
